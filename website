<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Customer Support Tickets – Phillip’s Pressure Warriors</title>
    <style>
        body { font-family: Arial, sans-serif; background:#eef2f6; padding:20px; }
        .box { background:white; padding:25px; border-radius:10px; max-width:700px; margin:auto; }
        label { display:block; margin-top:10px; }
        input, select, textarea { width:100%; padding:12px; margin-top:5px; border-radius:6px; border:1px solid #bbb; }
        button { margin-top:15px; padding:12px; background:#1e3d59; color:white; border:none; border-radius:6px; cursor:pointer; }
        button:hover { background:#162c42; }
        h2 { color:#1e3d59; }
        .ticket { background:#e8eef3; padding:15px; border-radius:8px; margin-top:15px; }
    </style>
</head>

<body>

<div class="box">
    <h2>Open a Support Ticket</h2>
    <p>Please explain your issue clearly so our staff can help you as fast as possible.</p>

    <label>Your Name</label>
    <input type="text" id="name">

    <label>Your Email</label>
    <input type="email" id="email">

    <label>Ticket Type</label>
    <select id="type">
        <option value="general">General Help</option>
        <option value="report">Reporting Ticket</option>
        <option value="website">Website Problem</option>
        <option value="complaint">Complaint Ticket</option>
    </select>

    <label>Explain Your Problem</label>
    <textarea id="msg" rows="6" placeholder="Tell us exactly what happened..."></textarea>

    <button onclick="submitTicket()">Submit Ticket</button>

    <div id="result"></div>
</div>

<script>
function submitTicket() {
    let name = document.getElementById("name").value;
    let email = document.getElementById("email").value;
    let type = document.getElementById("type").value;
    let msg = document.getElementById("msg").value;

    let route = "";

    if (type === "general") route = "Any worker past trial phase";
    if (type === "report") route = "Supervisor+";
    if (type === "website") route = "Supervisor+ (Website Issue)";
    if (type === "complaint") route = "Owner & Co‑Owner only";

    document.getElementById("result").innerHTML = `
        <div class="ticket">
            <h3>Ticket Submitted</h3>
            <p><strong>Name:</strong> ${name}</p>
            <p><strong>Email:</strong> ${email}</p>
            <p><strong>Type:</strong> ${type}</p>
            <p><strong>Message:</strong> ${msg}</p>
            <p><strong>Routed To:</strong> ${route}</p>
        </div>
    `;
}
</script>

</body>
</html>
